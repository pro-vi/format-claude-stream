{
  "name": "format-claude-stream",
  "version": "0.0.0",
  "description": "Formats output from `claude --output-format stream-json` as human-readable text",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "verify": "tsc && jest",
    "test": "jest",
    "fix": "prettier -w src"
  },
  "packageManager": "pnpm@10.26.0",
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": false,
    "quoteProps": "consistent",
    "semi": true,
    "tabWidth": 4,
    "trailingComma": "all"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@swc-node/register": "^1.11.1",
    "@swc/jest": "^0.2.39",
    "dedent": "^1.7.1",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
